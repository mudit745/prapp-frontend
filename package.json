{
  "name": "procurement-frontend",
  "version": "1.0.0",
  "description": "Procurement frontend for BTP",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:webapp": "node scripts/build-webapp.js",
    "build:html5-zip": "npm run build:webapp && cd webapp && npx bestzip ../prapp-frontend-content.zip .",
    "zip": "npm run build:html5-zip",
    "preview": "vite preview",
    "start": "npm run build && npm run build:webapp && serve -s webapp -l ${PORT:-3000}",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "cypress:open": "cypress open",
    "cypress:open:chrome": "cypress open --browser chrome",
    "cypress:open:electron": "cypress open --browser electron",
    "cypress:run": "cypress run",
    "cypress:run:chrome": "cypress run --browser chrome",
    "cypress:run:electron": "cypress run --browser electron",
    "cypress:run:headless": "cypress run --headless",
    "cypress:run:chrome:headless": "cypress run --browser chrome --headless",
    "cypress:run:electron:headless": "cypress run --browser electron --headless",
    "test:e2e": "cypress run",
    "test:e2e:chrome": "cypress run --browser chrome",
    "test:e2e:electron": "cypress run --browser electron"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dompurify": "^3.1.6",
    "serve": "^14.2.0",
    "lucide-react": "^0.556.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "bestzip": "^2.2.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.16",
    "cypress": "^15.7.1",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
